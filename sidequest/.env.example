# Copy to .env and fill in. Never commit real values (docs/TECHNICAL.md section 3).

ANTHROPIC_API_KEY=

# Used by the backend outside docker; docker-compose overrides this to point at the db service.
DATABASE_URL=postgresql+asyncpg://axiom:axiom@localhost:5432/axiom

MODEL_STRONG=claude-sonnet-5
MODEL_FAST=claude-haiku-4-5-20251001

MAX_RUN_COST_USD=0.75
# 30s in the founding brief, but full-document generation needs more; see
# PLANNING.md findings. Text streaming is never blocked by this branch.
ARTIFACT_TIMEOUT_S=420
GEN_RATE_LIMIT_PER_HOUR=10

# Incident switch: force text-only mode app-wide (SECURITY.md section 7).
ARTIFACTS_DISABLED=false

# Leave at llm until shadow-mode agreement and the local-routing golden-set
# gate have passed. Local runs read ml/router-distill/out by default.
ROUTER_MODE=llm

# Run the pipeline with no LLM calls (echoes the query back). Also implied
# when ANTHROPIC_API_KEY is empty, so a clean clone boots without a key.
ECHO_MODE=false

# Browser origins allowed to call the API. JSON list; must include the
# frontend origin or the browser blocks /api/ask at preflight.
CORS_ORIGINS=["http://localhost:3000"]

# Frontend: browser-visible base URL of the FastAPI backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Frontend server-side rewrite target for /vendor/* (docker: http://backend:8000).
API_BASE_INTERNAL=http://localhost:8000
