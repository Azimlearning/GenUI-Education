# Synapse backend — environment
# Copy to `.env`. Provider keys are OPTIONAL until P1 (the router degrades gracefully
# to scripted stub responses when a provider is not configured).

# ─── CORS ─── the Next.js dev origin allowed to call this backend
FRONTEND_ORIGIN=http://localhost:3000

# ─── LLM providers (multi-provider router — no hard default; see providers/config.py) ───
# Fill only the ones you use; leave the rest blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# ─── Learner store (D-11) ───
# dev default is in-memory; set to "sqlite" and a path for local persistence in P3.
LEARNER_STORE=memory
# LEARNER_STORE=sqlite
# LEARNER_STORE_PATH=./synapse.sqlite3
