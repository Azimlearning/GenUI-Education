# Copy to .env.local and fill in. Server-side only — never exposed to the client.

# Required. Primary provider for every pipeline step.
ANTHROPIC_API_KEY=

# Optional. Enables the fallback leg of the provider router (lib/router.ts).
# Without it, a provider failure degrades down the tier ladder instead.
OPENAI_API_KEY=

# Models are configured per role in lib/router.ts, not here:
#   fast   -> claude-haiku-4-5   (planner/checker/brief, slot fills, guide)
#   strong -> claude-sonnet-5    (Tier B screens, Tier C generated labs)
